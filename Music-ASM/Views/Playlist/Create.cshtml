@model Music_ASM.Models.Playlist

<h2>➕ Tạo Playlist</h2>

<form asp-action="Create" method="post">

    <input asp-for="Title" class="form-control mb-2" placeholder="Tên playlist" />

    <input asp-for="Description" class="form-control mb-2" placeholder="Mô tả" />


    <button type="submit" class="btn btn-success">Tạo</button>

</form>