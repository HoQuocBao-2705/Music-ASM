@model List<Music_ASM.Models.Genre>

@{
    ViewData["Title"] = "Quản lý thể loại";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">🎼 Quản lý thể loại</h2>
        <a asp-action="CreateGenre" class="btn btn-success rounded-pill px-4">
            <i class="fas fa-plus me-2"></i>Thêm thể loại
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên thể loại</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var genre in Model)
                    {
                        <tr>
                            <td class="align-middle">@genre.GenreId</td>
                            <td class="text-white fw-bold align-middle">@genre.Name</td>
                            <td class="align-middle">
                                <button onclick="editGenre(@genre.GenreId, '@genre.Name')"
                                        class="btn btn-sm btn-warning me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editGenreModal">
                                    <i class="fas fa-edit"></i> Sửa
                                </button>
                                <button onclick="confirmDeleteGenre(@genre.GenreId, '@genre.Name')"
                                        class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5" style="background-color: #181818; border-radius: 12px;">
            <i class="fas fa-tag" style="font-size: 64px; color: #b3b3b3;"></i>
            <h4 class="mt-3 text-white">Chưa có thể loại nào</h4>
            <p class="text-muted">Hãy thêm thể loại đầu tiên</p>
            <a asp-action="CreateGenre" class="btn btn-success rounded-pill px-4 mt-2">
                <i class="fas fa-plus me-2"></i>Thêm thể loại
            </a>
        </div>
    }
</div>

<div class="modal fade" id="editGenreModal" tabindex="-1" aria-labelledby="editGenreModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: #181818; border: none;">
            <div class="modal-header" style="border-bottom-color: #282828;">
                <h5 class="modal-title text-white" id="editGenreModalLabel">✏️ Sửa thể loại</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editGenreForm" method="post" asp-action="EditGenre">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="GenreId" id="editGenreId" />
                    <div class="mb-3">
                        <label class="form-label text-white">Tên thể loại</label>
                        <input type="text" name="Name" id="editGenreName" class="form-control" style="background-color: #282828; border: none; color: white;" required />
                    </div>
                </div>
                <div class="modal-footer" style="border-top-color: #282828;">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success rounded-pill">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editGenre(id, name) {
            document.getElementById('editGenreId').value = id;
            document.getElementById('editGenreName').value = name;
        }
        
        function confirmDeleteGenre(id, name) {
            if (confirm(`Bạn có chắc muốn xóa thể loại "${name}"?\nLưu ý: Chỉ xóa được thể loại không có bài hát nào!`)) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/AdminSongs/DeleteGenre?id=${id}`;
                
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token;
                    form.appendChild(tokenInput);
                }
                
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}