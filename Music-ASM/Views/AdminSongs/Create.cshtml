@model Music_ASM.Models.Song

<h2>➕ Thêm bài hát</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <!-- TITLE -->
    <input asp-for="Title" class="form-control mb-2" placeholder="Tên bài hát" />
    <span asp-validation-for="Title" class="text-danger"></span>

    <!-- FILE AUDIO -->
    <input type="file" name="audioFile" class="form-control mb-2" accept=".mp3" />

    <!-- COVER IMAGE -->
    <input type="file" name="imageFile" class="form-control mb-2" accept="image/*" />

    <!-- DURATION -->
    <input asp-for="Duration" type="number" min="1" class="form-control mb-2" placeholder="Thời lượng (giây)" />
    <span asp-validation-for="Duration" class="text-danger"></span>

    <!-- RELEASE DATE - THÊM MỚI -->
    <input asp-for="ReleaseDate" type="date" class="form-control mb-2" />
    <span asp-validation-for="ReleaseDate" class="text-danger"></span>

    <!-- ARTIST -->
    <select asp-for="ArtistId" asp-items="ViewBag.Artists" class="form-control mb-2">
        <option value="">-- Chọn nghệ sĩ --</option>
    </select>
    <span asp-validation-for="ArtistId" class="text-danger"></span>

    <!-- GENRE -->
    <select asp-for="GenreId" asp-items="ViewBag.Genres" class="form-control mb-2">
        <option value="">-- Chọn thể loại --</option>
    </select>
    <span asp-validation-for="GenreId" class="text-danger"></span>

    <button type="submit" class="btn btn-success">Lưu</button>
</form>