<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Music_ASM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Music_ASM.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
            body {
                background-color: #000;
                color: #fff;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                /* ✅ FIX DUY NHẤT */
                overflow-x: hidden;
                overflow-y: auto;
            }

            .sidebar {
                width: 260px;
                background-color: #000;
                height: calc(100vh - 90px);
                position: fixed;
                top: 0;
                left: 0;
                padding: 24px 12px;
                display: flex;
                flex-direction: column;
            }

            .nav-item {
                color: #b3b3b3;
                text-decoration: none;
                font-weight: bold;
                padding: 12px 16px;
                border-radius: 4px;
                display: flex;
                align-items: center;
                transition: color 0.2s ease;
            }

                .nav-item:hover, .nav-item.active {
                    color: #fff;
                }

                .nav-item i {
                    font-size: 1.2rem;
                    margin-right: 16px;
                    width: 24px;
                }

            .divider {
                height: 1px;
                background-color: #282828;
                margin: 16px 16px;
            }

            .main-wrapper {
                margin-left: 260px;
                width: calc(100% - 260px);
                /* ✅ FIX DUY NHẤT */
                min-height: calc(100vh - 90px);
                height: auto;
                background: linear-gradient(180deg, #2a2a2a 0%, #121212 100%);
                overflow-y: auto;
                border-radius: 8px;
                margin-top: 8px;
                
                /* Thêm dòng này để fix lỗi khuất nội dung */
                padding-bottom: 110px; 
            }

            .topbar {
                position: sticky;
                top: 0;
                background: rgba(18, 18, 18, 0.8);
                backdrop-filter: blur(10px);
                padding: 16px 32px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                z-index: 100;
            }

            .btn-upgrade {
                background-color: #fff;
                color: #000;
                border-radius: 500px;
                font-weight: bold;
                padding: 8px 32px;
                text-decoration: none;
            }

            .user-menu {
                background-color: #000;
                border-radius: 50px;
                padding: 4px;
                display: flex;
                align-items: center;
                gap: 8px;
                cursor: pointer;
                border: 1px solid #282828;
            }

                .user-menu img {
                    width: 32px;
                    height: 32px;
                    border-radius: 50%;
                    object-fit: cover;
                }

            .bottom-player {
                position: fixed;
                bottom: 0;
                left: 0;
                width: 100%;
                height: 90px;
                background-color: #181818;
                border-top: 1px solid #282828;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 16px;
                z-index: 1000;
            }

            .player-controls {
                display: flex;
                flex-direction: column;
                align-items: center;
                width: 40%;
            }

            .control-buttons {
                display: flex;
                align-items: center;
                gap: 24px;
                color: #b3b3b3;
                margin-bottom: 8px;
            }

            .btn-play-main {
                background-color: #fff;
                color: #000;
                width: 32px;
                height: 32px;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
                cursor: pointer;
            }

            .progress-container {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 0.75rem;
                color: #b3b3b3;
            }

            .progress-bar-bg {
                flex-grow: 1;
                height: 4px;
                background-color: #4d4d4d;
                border-radius: 2px;
                cursor: pointer;
            }

            .progress-bar-fill {
                width: 0%; /* Để mặc định là 0% */
                height: 100%;
                background-color: #fff;
                border-radius: 2px;
            }

            .search-box {
                display: flex;
                align-items: center;
                background-color: #242424;
                border-radius: 500px;
                padding: 6px 15px;
                width: 350px;
            }

                .search-box input {
                    background: transparent;
                    border: none;
                    outline: none;
                    color: #fff;
                    width: 100%;
                }
            
            /* Thêm style nhỏ cho input type range (volume) */
            input[type=range] {
                cursor: pointer;
            }
            /* Avatar chữ cái đầu */
            .avatar-initials {
                transition: all 0.2s ease;
            }

            .user-menu:hover .avatar-initials {
                transform: scale(1.05);
            }

            /* Dropdown menu style */
            .dropdown-menu-dark {
                background-color: #282828;
                border: 1px solid #3e3e3e;
                border-radius: 8px;
            }

            .dropdown-menu-dark .dropdown-item {
                    color: #b3b3b3;
                    transition: all 0.2s;
                }

                    .dropdown-menu-dark .dropdown-item:hover {
                        background-color: #3e3e3e;
                        color: #fff;
                    }
            .btn-dark.rounded-circle {
                width: 32px;
                height: 32px;
                display: flex;
                align-items: center;
                justify-content: center;
                background-color: rgba(0, 0, 0, 0.7);
                transition: all 0.2s;
            }

            .btn-dark.rounded-circle:hover {
                background-color: rgba(0, 0, 0, 0.9);
                transform: scale(1.05);
            }

            .btn-dark.rounded-circle:active {
                transform: scale(0.95);
            }
            /* Thêm vào style */
            .row.text-center .col-4 > div:hover {
                transform: translateY(-3px);
                background-color: #333 !important;
            }

    </style>
</head>

<body>

    <nav class="sidebar">
        <div class="mb-4 px-3">
            <h3 class="fw-bold" style="color: #fff;">
                <i class="fab fa-spotify me-2" style="color: #1db954;"></i>Music-ASM
            </h3>
        </div>

        <a asp-controller="Home" asp-action="Index" class="nav-item active">
            <i class="fas fa-home"></i> Trang chủ
        </a>

        <a asp-controller="Home" asp-action="Search" class="nav-item">
            <i class="fas fa-search"></i> Tìm kiếm
        </a>

        <a asp-controller="Home" asp-action="Library" class="nav-item">
            <i class="fas fa-book-open"></i> Thư viện
        </a>

        <div class="divider"></div>

        <a asp-controller="Playlist" asp-action="Index" class="nav-item">
            <i class="fas fa-plus-square"></i> Tạo Playlist
        </a>

        <a asp-controller="Home" asp-action="History" class="nav-item">
            <i class="fas fa-history"></i> Lịch sử
        </a>
    </nav>

    <main class="main-wrapper">

        <header class="topbar">

            <div class="d-flex align-items-center gap-3">
                <button id="btnBack" class="btn btn-dark rounded-circle" onclick="goBack()" title="Quay lại (Alt + ←)">
                    <i class="fas fa-chevron-left"></i>
                </button>
    
                <button id="btnForward" class="btn btn-dark rounded-circle" onclick="goForward()" title="Tiến tới (Alt + →)">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <form asp-controller="Home" asp-action="Search" method="get" class="search-box">
                    <input type="text" name="keyword" placeholder="Bạn muốn nghe gì?" value="@ViewBag.Keyword" />
                </form>
            </div>

            <div class="d-flex align-items-center gap-3">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold" style="color: #b3b3b3;">Đăng ký</a>
                    <a asp-controller="Account" asp-action="Login" class="btn-upgrade">Đăng nhập</a>
                }
                else
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="AdminSongs" asp-action="Artists" class="nav-item">
                            🎤 Nghệ sĩ
                        </a>

                        <a asp-controller="AdminSongs" asp-action="Genres" class="nav-item">
                            🎼 Thể loại
                        </a>
                        <a href="/AdminSongs" class="nav-item">⚙️ Quản lý Songs</a>
                    }

                    <div class="dropdown">
                        <div class="user-menu" data-bs-toggle="dropdown" style="cursor: pointer;">
                            @{
                                // Lấy thông tin từ claims
                                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
                                var username = User.Identity?.Name ?? "User";
                                var avatarUrl = User.FindFirst("Avatar")?.Value;
                                var initials = Music_ASM.Helpers.UserHelper.GetInitials(fullName);
                                var avatarColor = Music_ASM.Helpers.UserHelper.GetAvatarColor(fullName);
                            }
        
                            @if (!string.IsNullOrEmpty(avatarUrl) && avatarUrl != "/images/default-avatar.png")
                            {
                                <img src="@avatarUrl" alt="Avatar" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="avatar-initials" style="width: 32px; height: 32px; border-radius: 50%; background-color: @avatarColor; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; color: white;">
                                    @initials
                                </div>
                            }
                            <span class="fw-bold text-white ms-2">@username</span>
                            <i class="fas fa-caret-down text-white ms-1"></i>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end mt-2" style="background-color: #282828; border: 1px solid #3e3e3e; border-radius: 8px;">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="UpgradePremium">
                                <i class="fas fa-crown me-2"></i>Nâng cấp Premium
                            </a></li>                           
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </div>

        </header>

        <div class="p-4" style="padding-bottom: 80px;">
            @RenderBody()
        </div>

    </main>

    <footer class="bottom-player">
        
        <div class="d-flex align-items-center gap-3" style="width: 30%;">
            <img id="player-cover" src="https://via.placeholder.com/56" alt="Cover" style="width: 56px; height: 56px; border-radius: 4px; object-fit: cover; display: none;">
            <div>
                <div id="player-title" class="fw-bold text-white">Chưa phát bài nào</div>
                <div id="player-artist" style="font-size: 0.8rem; color: #b3b3b3;">---</div>
            </div>
        </div>

        <div class="player-controls">
            <div class="control-buttons">
                <i class="fas fa-step-backward" style="cursor: pointer;" onclick="prevSong()"></i>
                
                <div class="btn-play-main" onclick="togglePlay()">
                    <i id="play-icon" class="fas fa-play"></i>
                </div>
                
                <i class="fas fa-step-forward" style="cursor: pointer;" onclick="nextSong()"></i>
            </div>
            
            <div class="progress-container">
                <span id="current-time">0:00</span>
                <div class="progress-bar-bg" onclick="seek(event)">
                    <div id="progress-bar" class="progress-bar-fill"></div>
                </div>
                <span id="duration">0:00</span>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 justify-content-end" style="width: 30%;">
            <i class="fas fa-volume-up text-secondary"></i>
            <input type="range" id="volume" min="0" max="1" step="0.1" value="1" style="width: 100px;">
        </div>

    </footer>
    
    <audio id="audio-player"></audio>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
    
    <script>
        // ========== PLAYER TOÀN CỤC VỚI LOCALSTORAGE ==========
        let audio = document.getElementById("audio-player");
        let isInitialized = false;
        
        // 🎯 BIẾN THEO DÕI THỜI GIAN NGHE
        let listenStartTime = null;
        let currentSongId = null;

        // Khôi phục trạng thái từ localStorage khi tải trang
        function restorePlayerState() {
            const savedSong = localStorage.getItem('currentSong');
            const savedTime = localStorage.getItem('currentTime');
            const savedPlaying = localStorage.getItem('isPlaying') === 'true';
            
            if (savedSong) {
                try {
                    const songData = JSON.parse(savedSong);
                    document.getElementById("player-title").innerText = songData.title;
                    document.getElementById("player-artist").innerText = songData.artist;
                    
                    let coverImg = document.getElementById("player-cover");
                    if (songData.cover) {
                        coverImg.src = songData.cover;
                        coverImg.style.display = "block";
                    } else {
                        coverImg.style.display = "none";
                    }
                    
                    audio.src = songData.filePath;
                    // Phục hồi ID bài hát để tính giờ
                    currentSongId = localStorage.getItem('currentSongId');
                    
                    if (savedTime && !isNaN(parseFloat(savedTime))) {
                        audio.currentTime = parseFloat(savedTime);
                    }
                    
                    if (savedPlaying) {
                        listenStartTime = Date.now(); // Bắt đầu tính giờ lại nếu đang phát
                        audio.play().catch(e => console.log("Auto-play bị chặn:", e));
                        setPlayIcon(true);
                    } else {
                        setPlayIcon(false);
                    }
                } catch(e) {
                    console.log("Khôi phục thất bại:", e);
                }
            }
            isInitialized = true;
        }
        
        // Lưu trạng thái hiện tại
        function savePlayerState() {
            if (!isInitialized) return;
            
            const currentSong = {
                filePath: audio.src,
                title: document.getElementById("player-title").innerText,
                artist: document.getElementById("player-artist").innerText,
                cover: document.getElementById("player-cover").src
            };
            
            if (audio.src && audio.src !== window.location.href) {
                localStorage.setItem('currentSong', JSON.stringify(currentSong));
                localStorage.setItem('currentTime', audio.currentTime);
                localStorage.setItem('isPlaying', !audio.paused);
                if (currentSongId) {
                    localStorage.setItem('currentSongId', currentSongId);
                }
            }
        }
        
        // Lưu trạng thái trước khi rời trang
        window.addEventListener('beforeunload', function() {
            savePlayerState();
            trackListeningTime(); // Ghi nhận thời gian nghe trước khi thoát
        });
        
        // Lưu định kỳ mỗi 5 giây
        setInterval(function() {
            if (audio.src && !audio.paused) {
                savePlayerState();
            }
        }, 5000);
        
        // Lưu khi timeupdate
        audio.addEventListener('timeupdate', function() {
            if (audio.src && !audio.paused && isInitialized) {
                localStorage.setItem('currentTime', audio.currentTime);
            }
        });
        
        // ========== DANH SÁCH PHÁT TOÀN CỤC ==========
        let currentPlaylist = [];
        let currentIndex = -1;
        
        function setPlaylist(songIds, newSongId) {
            currentPlaylist = songIds;
            currentIndex = currentPlaylist.indexOf(newSongId);
            localStorage.setItem('currentPlaylist', JSON.stringify(currentPlaylist));
            localStorage.setItem('currentIndex', currentIndex);
            console.log("Playlist updated:", currentPlaylist, "Current index:", currentIndex);
        }
        
        function restorePlaylist() {
            const savedPlaylist = localStorage.getItem('currentPlaylist');
            const savedIndex = localStorage.getItem('currentIndex');
            if (savedPlaylist) {
                currentPlaylist = JSON.parse(savedPlaylist);
                currentIndex = parseInt(savedIndex);
            }
        }
        
        function nextSong() {
            if (currentPlaylist.length === 0) return;
            if (currentIndex < currentPlaylist.length - 1) {
                currentIndex++;
            } else {
                currentIndex = 0;
            }
            playSongById(currentPlaylist[currentIndex]);
        }
        
        function prevSong() {
            if (currentPlaylist.length === 0) return;
            if (currentIndex > 0) {
                currentIndex--;
            } else {
                currentIndex = currentPlaylist.length - 1;
            }
            playSongById(currentPlaylist[currentIndex]);
        }
        
        // Hàm phát bài theo ID
        function playSongById(songId) {
            // Ghi nhận thời gian bài trước đó (nếu có)
            trackListeningTime();
            
            // Ghi nhận bài hát mới và thời gian bắt đầu
            currentSongId = songId;
            listenStartTime = Date.now();


            fetch(`/Home/PlaySong?id=${songId}`)
                .then(res => res.json())
                .then(data => {
                    audio.src = data.filePath;
                    audio.play();
                    
                    document.getElementById("player-title").innerText = data.title;
                    document.getElementById("player-artist").innerText = data.artist;
                    
                    let coverImg = document.getElementById("player-cover");
                    if (data.cover) {
                        coverImg.src = data.cover;
                        coverImg.style.display = "block";
                    } else {
                        coverImg.style.display = "none";
                    }
                    
                    setPlayIcon(true);
                    savePlayerState();
                })
                .catch(error => {
                    console.error("Error playing song:", error);
                });
        }
        
        function playSong(id) {
            let songIds = [];
            document.querySelectorAll('[onclick^="playSong"]').forEach(btn => {
                let match = btn.getAttribute('onclick').match(/playSong\((\d+)\)/);
                if (match) songIds.push(parseInt(match[1]));
            });
            
            if (songIds.length === 0) songIds = [id];
            
            setPlaylist(songIds, id);
            playSongById(id);
        }
        
        // 🎯 HÀM GHI NHẬN THỜI GIAN NGHE
            function trackListeningTime(isCompleted = false) {
            if (currentSongId && listenStartTime) {
                const duration = Math.floor((Date.now() - listenStartTime) / 1000);
                if (duration >= 5) { // Chỉ ghi nhận nếu nghe >= 5 giây
                        fetch('/Home/TrackListening?songId=' + currentSongId + '&duration=' + duration, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            songId: currentSongId,
                            duration: duration
                        })
                    }).catch(err => console.log("Lỗi ghi nhận thời gian:", err));
                }
                listenStartTime = null;
                // Giữ lại currentSongId vì localStorage có thể cần dùng
            }
        }

        // Tự động chuyển bài và ghi nhận
            audio.addEventListener("ended", () => {
                trackListeningTime(true);
                nextSong();
                savePlayerState();
            });

        function togglePlay() {
            if (!audio.src) return;
            if (audio.paused) {
                audio.play();
                setPlayIcon(true);
                listenStartTime = Date.now(); // Tiếp tục tính giờ
            } else {
                audio.pause();
                setPlayIcon(false);
                trackListeningTime(); // Dừng tính giờ và gửi lên server
            }
            savePlayerState();
        }
        
        function setPlayIcon(playing) {
            let icon = document.getElementById("play-icon");
            icon.classList.remove("fa-play", "fa-pause");
            icon.classList.add(playing ? "fa-pause" : "fa-play");
        }
        
        // Thanh tiến trình
        audio.addEventListener("timeupdate", () => {
            if (!audio.duration) return;
            let percent = (audio.currentTime / audio.duration) * 100;
            document.getElementById("progress-bar").style.width = percent + "%";
            document.getElementById("current-time").innerText = formatTime(audio.currentTime);
            document.getElementById("duration").innerText = formatTime(audio.duration);
        });
        
        function formatTime(seconds) {
            if (isNaN(seconds)) return "0:00";
            let m = Math.floor(seconds / 60);
            let s = Math.floor(seconds % 60);
            return m + ":" + (s < 10 ? "0" + s : s);
        }
        
        function seek(e) {
            if (!audio.src) return;
            let rect = e.currentTarget.getBoundingClientRect();
            let percent = (e.clientX - rect.left) / rect.width;
            audio.currentTime = percent * audio.duration;
            savePlayerState();
        }
        
        // Volume
        const volumeSlider = document.getElementById("volume");
        if (volumeSlider) {
            const savedVolume = localStorage.getItem('volume');
            if (savedVolume) {
                audio.volume = parseFloat(savedVolume);
                volumeSlider.value = savedVolume;
            }
            
            volumeSlider.addEventListener("input", function() {
                audio.volume = this.value;
                localStorage.setItem('volume', this.value);
            });
        }
        
        audio.addEventListener("play", () => {
            setPlayIcon(true);
            savePlayerState();
        });
        
        audio.addEventListener("pause", () => {
            setPlayIcon(false);
            savePlayerState();
        });
        
        // Khởi tạo khi trang load
        document.addEventListener('DOMContentLoaded', function() {
            restorePlaylist();
            restorePlayerState();
        });

        // Chức năng nút Back và Forward
        function goBack() {
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        function goForward() {
            window.history.forward();
        }

        function updateNavButtons() {
            const btnBack = document.getElementById('btnBack');
            if (btnBack) {
                btnBack.style.opacity = window.history.length > 1 ? '1' : '0.5';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            updateNavButtons();
            window.addEventListener('popstate', function() {
                updateNavButtons();
            });
        });

        document.addEventListener('keydown', function(event) {
            if (event.altKey && event.key === 'ArrowLeft') {
                event.preventDefault();
                goBack();
            }
            if (event.altKey && event.key === 'ArrowRight') {
                event.preventDefault();
                goForward();
            }
        });       
        
    </script>

</body>
</html>