<!DOCTYPE html>
<html lang="vi">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Music_ASM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Music_ASM.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background-color: #000;
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            /* ✅ FIX DUY NHẤT */
            overflow-x: hidden;
            overflow-y: auto;
        }

        .sidebar {
            width: 260px;
            background-color: #000;
            height: calc(100vh - 90px);
            position: fixed;
            top: 0;
            left: 0;
            padding: 24px 12px;
            display: flex;
            flex-direction: column;
        }

        .nav-item {
            color: #b3b3b3;
            text-decoration: none;
            font-weight: bold;
            padding: 12px 16px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            transition: color 0.2s ease;
        }

            .nav-item:hover, .nav-item.active {
                color: #fff;
            }

            .nav-item i {
                font-size: 1.2rem;
                margin-right: 16px;
                width: 24px;
            }

        .divider {
            height: 1px;
            background-color: #282828;
            margin: 16px 16px;
        }

        .main-wrapper {
            margin-left: 260px;
            width: calc(100% - 260px);
            /* ✅ FIX DUY NHẤT */
            min-height: calc(100vh - 90px);
            height: auto;
            background: linear-gradient(180deg, #2a2a2a 0%, #121212 100%);
            overflow-y: auto;
            border-radius: 8px;
            margin-top: 8px;
        }

        .topbar {
            position: sticky;
            top: 0;
            background: rgba(18, 18, 18, 0.8);
            backdrop-filter: blur(10px);
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
        }

        .btn-upgrade {
            background-color: #fff;
            color: #000;
            border-radius: 500px;
            font-weight: bold;
            padding: 8px 32px;
            text-decoration: none;
        }

        .user-menu {
            background-color: #000;
            border-radius: 50px;
            padding: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: 1px solid #282828;
        }

            .user-menu img {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                object-fit: cover;
            }

        .bottom-player {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 90px;
            background-color: #181818;
            border-top: 1px solid #282828;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 16px;
            z-index: 1000;
        }

        .player-controls {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 40%;
        }

        .control-buttons {
            display: flex;
            align-items: center;
            gap: 24px;
            color: #b3b3b3;
            margin-bottom: 8px;
        }

        .btn-play-main {
            background-color: #fff;
            color: #000;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .progress-container {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.75rem;
            color: #b3b3b3;
        }

        .progress-bar-bg {
            flex-grow: 1;
            height: 4px;
            background-color: #4d4d4d;
            border-radius: 2px;
        }

        .progress-bar-fill {
            width: 30%;
            height: 100%;
            background-color: #fff;
            border-radius: 2px;
        }

        .search-box {
            display: flex;
            align-items: center;
            background-color: #242424;
            border-radius: 500px;
            padding: 6px 15px;
            width: 350px;
        }

            .search-box input {
                background: transparent;
                border: none;
                outline: none;
                color: #fff;
                width: 100%;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <nav class="sidebar">
        <div class="mb-4 px-3">
            <h3 class="fw-bold" style="color: #fff;">
                <i class="fab fa-spotify me-2" style="color: #1db954;"></i>Music-ASM
            </h3>
        </div>

        <a asp-controller="Home" asp-action="Index" class="nav-item active">
            <i class="fas fa-home"></i> Trang chủ
        </a>

        <a asp-controller="Home" asp-action="Search" class="nav-item">
            <i class="fas fa-search"></i> Tìm kiếm
        </a>

        <a asp-controller="Home" asp-action="Library" class="nav-item">
            <i class="fas fa-book-open"></i> Thư viện
        </a>

        <div class="divider"></div>

        <a href="#" class="nav-item">
            <i class="fas fa-plus-square"></i> Tạo Playlist
        </a>
    </nav>

    <!-- MAIN -->
    <main class="main-wrapper">

        <!-- TOPBAR -->
        <header class="topbar">

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-dark rounded-circle">
                    <i class="fas fa-chevron-left"></i>
                </button>

                <form asp-controller="Home" asp-action="Search" method="get" class="search-box">
                    <input type="text" name="keyword" placeholder="Bạn muốn nghe gì?" />
                </form>
            </div>

            <!-- LOGIN / USER -->
            <div class="d-flex align-items-center gap-3">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold" style="color: #b3b3b3;">Đăng ký</a>
                    <a asp-controller="Account" asp-action="Login" class="btn-upgrade">Đăng nhập</a>
                }
                else
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/AdminSongs" class="nav-item">⚙️ Quản lý Songs</a>
                    }

                    <!-- ✅ FIX DROPDOWN -->
                    <div class="dropdown">
                        <div class="user-menu" data-bs-toggle="dropdown">
                            <img src="@(User.FindFirst("Avatar")?.Value ?? "/images/default-avatar.png")">
                            <span class="fw-bold text-white">@User.Identity.Name</span>
                            <i class="fas fa-caret-down text-white"></i>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end mt-2">
                            <li><a class="dropdown-item" href="#">Hồ sơ</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </div>

        </header>

        <!-- CONTENT -->
        <div class="p-4">
            @RenderBody()
        </div>

    </main>

    <!-- PLAYER -->
    <footer class="bottom-player">
        <div>Chưa phát bài nào</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>