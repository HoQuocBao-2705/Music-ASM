<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Music_ASM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Music_ASM.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* Reset và base styles nâng cao */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #000000 100%);
            color: #fff;
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
            overflow-y: auto;
        }

        /* Custom Scrollbar đẹp hơn */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(26, 26, 26, 0.5);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #1db954, #1ed760);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #1ed760, #1db954);
        }

        /* Sidebar hiện đại */
        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, rgba(10, 10, 10, 0.98) 0%, rgba(0, 0, 0, 0.98) 100%);
            height: calc(100vh - 90px);
            position: fixed;
            top: 0;
            left: 0;
            padding: 24px 12px;
            display: flex;
            flex-direction: column;
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 100;
            transition: all 0.3s ease;
        }

        .logo {
            background: linear-gradient(135deg, #1db954, #1ed760, #1db954);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            animation: shimmer 3s infinite;
        }

        keyframes shimmer {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .logo i {
            background: linear-gradient(135deg, #1db954, #1ed760);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .nav-item {
            color: #b3b3b3;
            text-decoration: none;
            font-weight: 500;
            padding: 12px 16px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            margin: 2px 0;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(29, 185, 84, 0.15);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .nav-item:hover::before {
            width: 100%;
            height: 100%;
        }

        .nav-item:hover, .nav-item.active {
            color: #fff;
            background: linear-gradient(90deg, rgba(29, 185, 84, 0.15), rgba(29, 185, 84, 0.05));
            transform: translateX(5px);
        }

        .nav-item.active {
            color: #1db954;
            background: linear-gradient(90deg, rgba(29, 185, 84, 0.2), rgba(29, 185, 84, 0.05));
            border-left: 3px solid #1db954;
        }

        .nav-item i {
            font-size: 1.3rem;
            margin-right: 16px;
            width: 24px;
            transition: transform 0.3s ease;
        }

        .nav-item:hover i {
            transform: scale(1.1);
        }

        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            margin: 16px 16px;
        }

        /* Main wrapper cải tiến */
        .main-wrapper {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: calc(100vh - 90px);
            height: auto;
            background: linear-gradient(180deg, rgba(30, 30, 35, 0.95) 0%, rgba(18, 18, 18, 0.98) 100%);
            overflow-y: auto;
            border-radius: 16px 0 0 16px;
            margin-top: 8px;
            padding-bottom: 110px;
            position: relative;
            transition: all 0.3s ease;
        }

        /* Topbar đẹp hơn */
        .topbar {
            position: sticky;
            top: 0;
            background: rgba(18, 18, 18, 0.95);
            backdrop-filter: blur(20px);
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

        /* Button upgrade premium */
        .btn-upgrade {
            background: linear-gradient(135deg, #ffd700, #ffed4e, #ffd700);
            background-size: 200% auto;
            color: #000;
            border-radius: 500px;
            font-weight: 700;
            padding: 10px 32px;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            border: none;
            letter-spacing: 0.5px;
        }

        .btn-upgrade:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 215, 0, 0.3);
            background-position: right center;
        }

        /* User menu */
        .user-menu {
            background: linear-gradient(135deg, #1a1a1a, #0a0a0a);
            border-radius: 50px;
            padding: 6px 12px 6px 6px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .user-menu:hover {
            border-color: #1db954;
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(29, 185, 84, 0.2);
        }

        .user-menu img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #1db954;
        }

        /* Bottom player nâng cấp */
        .bottom-player {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 90px;
            background: linear-gradient(90deg, #181818, #1a1a1a, #181818);
            border-top: 1px solid rgba(29, 185, 84, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 24px;
            z-index: 1000;
            backdrop-filter: blur(20px);
            box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.5);
            transition: all 0.3s ease;
        }

        .player-controls {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 40%;
            gap: 8px;
        }

        .control-buttons {
            display: flex;
            align-items: center;
            gap: 28px;
            color: #b3b3b3;
        }

        .control-buttons i {
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 1.2rem;
        }

        .control-buttons i:hover {
            color: #fff;
            transform: scale(1.15);
        }

        /* Nút play chính đẹp hơn */
        .btn-play-main {
            background: linear-gradient(135deg, #1db954, #1ed760);
            color: #000;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
        }

        .btn-play-main:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(29, 185, 84, 0.4);
        }

        .btn-play-main:active {
            transform: scale(0.95);
        }

        .btn-play-main i {
            font-size: 1.2rem;
            color: #000;
        }

        /* Progress bar đẹp */
        .progress-container {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.75rem;
            color: #b3b3b3;
        }

        .progress-bar-bg {
            flex-grow: 1;
            height: 5px;
            background-color: rgba(64, 64, 64, 0.8);
            border-radius: 3px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: height 0.2s ease;
        }

        .progress-bar-bg:hover {
            height: 8px;
        }

        .progress-bar-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #1db954, #1ed760);
            border-radius: 3px;
            position: relative;
            transition: width 0.1s linear;
            box-shadow: 0 0 5px rgba(29, 185, 84, 0.5);
        }

        .progress-bar-fill::after {
            content: '';
            position: absolute;
            right: -4px;
            top: 50%;
            transform: translateY(-50%);
            width: 10px;
            height: 10px;
            background: #fff;
            border-radius: 50%;
            opacity: 0;
            transition: opacity 0.2s ease;
            box-shadow: 0 0 8px rgba(29, 185, 84, 0.8);
        }

        .progress-bar-bg:hover .progress-bar-fill::after {
            opacity: 1;
        }

        /* Search box nâng cấp */
        .search-box {
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, #242424, #1e1e1e);
            border-radius: 500px;
            padding: 10px 20px;
            width: 350px;
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .search-box:focus-within {
            border-color: #1db954;
            box-shadow: 0 0 0 3px rgba(29, 185, 84, 0.2);
            background: #2a2a2a;
            transform: scale(1.02);
        }

        .search-box input {
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            width: 100%;
            font-size: 0.9rem;
            font-weight: 400;
        }

        .search-box input::placeholder {
            color: #8a8a8a;
            font-weight: 300;
        }

        /* Volume slider đẹp */
        input[type=range] {
            cursor: pointer;
            height: 4px;
            border-radius: 2px;
            background: #404040;
            -webkit-appearance: none;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #1db954;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 0 5px rgba(29, 185, 84, 0.5);
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: scale(1.3);
            background: #1ed760;
        }

        /* Avatar initials */
        .avatar-initials {
            transition: all 0.2s ease;
            font-weight: 700;
        }

        .user-menu:hover .avatar-initials {
            transform: scale(1.05);
        }

        /* Dropdown menu */
        .dropdown-menu-dark {
            background: linear-gradient(135deg, #282828, #202020);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            backdrop-filter: blur(10px);
            padding: 8px;
        }

        .dropdown-menu-dark .dropdown-item {
            color: #b3b3b3;
            transition: all 0.2s ease;
            padding: 10px 20px;
            border-radius: 8px;
            margin: 2px 0;
        }

        .dropdown-menu-dark .dropdown-item:hover {
            background: rgba(29, 185, 84, 0.2);
            color: #fff;
            transform: translateX(5px);
        }

        /* Navigation buttons */
        .btn-dark.rounded-circle {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border-radius: 50%;
        }

        .btn-dark.rounded-circle:hover {
            background: rgba(0, 0, 0, 0.9);
            transform: scale(1.1);
            border-color: #1db954;
        }

        /* Card hover effect nâng cấp */
        .row.text-center .col-4 > div, .card-hover {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border-radius: 12px;
            overflow: hidden;
            position: relative;
        }

        .row.text-center .col-4 > div:hover, .card-hover:hover {
            transform: translateY(-8px);
            background: linear-gradient(135deg, #333, #2a2a2a) !important;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
        }

        /* Player info */
        #player-title {
            font-weight: 700;
            transition: color 0.2s ease;
            font-size: 1rem;
        }

        #player-title:hover {
            color: #1db954;
            cursor: pointer;
        }

        #player-artist {
            font-size: 0.8rem;
            color: #b3b3b3;
            transition: color 0.2s ease;
        }

        #player-artist:hover {
            color: #ddd;
        }

        #player-cover {
            transition: transform 0.3s ease;
            cursor: pointer;
        }

        #player-cover:hover {
            transform: scale(1.05);
        }

        /* Smooth scroll */
        .main-wrapper {
            scroll-behavior: smooth;
        }

        /* Tooltip style đẹp */
        [title] {
            position: relative;
        }

        [title]:hover::after {
            content: attr(title);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.95);
            color: #1db954;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            white-space: nowrap;
            z-index: 1000;
            margin-bottom: 8px;
            pointer-events: none;
            border: 1px solid rgba(29, 185, 84, 0.3);
            backdrop-filter: blur(5px);
        }

        /* Focus styles */
        button:focus, a:focus, input:focus {
            outline: 2px solid #1db954;
            outline-offset: 2px;
        }

        /* Animation cho loading */
        keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .main-wrapper .p-4 {
            animation: fadeIn 0.5s ease-out;
        }

        /* Notification toast style */
        .toast-notification {
            position: fixed;
            bottom: 100px;
            right: 20px;
            background: linear-gradient(135deg, #1db954, #1ed760);
            color: #000;
            padding: 12px 20px;
            border-radius: 12px;
            font-weight: 600;
            z-index: 2000;
            animation: slideIn 0.3s ease-out;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }

        keyframes slideIn {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
audio {
    display: none;
}
}
    </style>
</head>

<body>

    <nav class="sidebar">
        <div class="mb-4 px-3">
            <h3 class="fw-bold logo">
                <i class="fab fa-spotify me-2"></i>Music-ASM
            </h3>
        </div>

        <a asp-controller="Home" asp-action="Index" class="nav-item active">
            <i class="fas fa-home"></i> Trang chủ
        </a>

        <a asp-controller="Home" asp-action="Search" class="nav-item">
            <i class="fas fa-search"></i> Tìm kiếm
        </a>

        <a asp-controller="Home" asp-action="Library" class="nav-item">
            <i class="fas fa-book-open"></i> Thư viện
        </a>

        <div class="divider"></div>

        <a asp-controller="Playlist" asp-action="Index" class="nav-item">
            <i class="fas fa-plus-square"></i> Tạo Playlist
        </a>

        <a asp-controller="Home" asp-action="History" class="nav-item">
            <i class="fas fa-history"></i> Lịch sử
        </a>
    </nav>

    <main class="main-wrapper">

        <header class="topbar">

            <div class="d-flex align-items-center gap-3">
                <button id="btnBack" class="btn-dark rounded-circle" onclick="goBack()" title="Quay lại (Alt + ←)">
                    <i class="fas fa-chevron-left"></i>
                </button>
    
                <button id="btnForward" class="btn-dark rounded-circle" onclick="goForward()" title="Tiến tới (Alt + →)">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <form asp-controller="Home" asp-action="Search" method="get" class="search-box">
                    <i class="fas fa-search" style="color: #8a8a8a; margin-right: 12px;"></i>
                    <input type="text" name="keyword" placeholder="Bạn muốn nghe gì?" value="@ViewBag.Keyword" />
                </form>
            </div>

            <div class="d-flex align-items-center gap-3">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-semibold" style="color: #b3b3b3; transition: all 0.2s;" onmouseover="this.style.color='#1db954'; this.style.transform='translateY(-1px)'" onmouseout="this.style.color='#b3b3b3'; this.style.transform='translateY(0)'">Đăng ký</a>
                    <a asp-controller="Account" asp-action="Login" class="btn-upgrade">Đăng nhập</a>
                }
                else
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="AdminSongs" asp-action="Artists" class="nav-item" style="padding: 8px 12px; margin: 0;">
                            🎤 Nghệ sĩ
                        </a>
                        <a asp-controller="AdminSongs" asp-action="Genres" class="nav-item" style="padding: 8px 12px; margin: 0;">
                            🎼 Thể loại
                        </a>
                        <a href="/AdminSongs" class="nav-item" style="padding: 8px 12px; margin: 0;">⚙️ Quản lý Songs</a>
                    }

                    <div class="dropdown">
                        <div class="user-menu" data-bs-toggle="dropdown" style="cursor: pointer;">
                            @{
                                var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
                                var username = User.Identity?.Name ?? "User";
                                var avatarUrl = User.FindFirst("Avatar")?.Value;
                                var initials = Music_ASM.Helpers.UserHelper.GetInitials(fullName);
                                var avatarColor = Music_ASM.Helpers.UserHelper.GetAvatarColor(fullName);
                            }
        
                            @if (!string.IsNullOrEmpty(avatarUrl) && avatarUrl != "/images/default-avatar.png")
                            {
                                <img src="@avatarUrl" alt="Avatar" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="avatar-initials" style="width: 32px; height: 32px; border-radius: 50%; background-color: @avatarColor; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 14px; color: white;">
                                    @initials
                                </div>
                            }
                            <span class="fw-semibold text-white ms-2">@username</span>
                            <i class="fas fa-caret-down text-white ms-1"></i>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end mt-2">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Hồ sơ</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="UpgradePremium">
                                <i class="fas fa-crown me-2" style="color: #ffd700;"></i>Nâng cấp Premium
                            </a></li>                           
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </div>

        </header>

        <div class="p-4" style="padding-bottom: 80px;">
            @RenderBody()
        </div>

    </main>

    <footer class="bottom-player">
        
        <div class="d-flex align-items-center gap-3" style="width: 30%;">
            <img id="player-cover" src="https://via.placeholder.com/56" alt="Cover" style="width: 56px; height: 56px; border-radius: 12px; object-fit: cover; display: none; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);">
            <div>
                <div id="player-title" class="fw-bold text-white" style="cursor: pointer;" onclick="togglePlayInfo()">Chưa phát bài nào</div>
                <div id="player-artist" style="font-size: 0.8rem; color: #b3b3b3;">---</div>
            </div>
        </div>

        <div class="player-controls">
            <div class="control-buttons">
                <i class="fas fa-step-backward" style="cursor: pointer;" onclick="prevSong()" title="Bài trước"></i>
                
                <div class="btn-play-main" onclick="togglePlay()">
                    <i id="play-icon" class="fas fa-play"></i>
                </div>
                
                <i class="fas fa-step-forward" style="cursor: pointer;" onclick="nextSong()" title="Bài tiếp"></i>
            </div>
            
            <div class="progress-container">
                <span id="current-time">0:00</span>
                <div class="progress-bar-bg" onclick="seek(event)">
                    <div id="progress-bar" class="progress-bar-fill"></div>
                </div>
                <span id="duration">0:00</span>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 justify-content-end" style="width: 30%;">
            <i class="fas fa-volume-up" style="color: #b3b3b3; cursor: pointer; transition: color 0.2s;" onclick="toggleMute()" title="Âm lượng" onmouseover="this.style.color='#1db954'" onmouseout="this.style.color='#b3b3b3'"></i>
            <input type="range" id="volume" min="0" max="1" step="0.05" value="1" style="width: 100px;">
        </div>

    </footer>
    
    <audio id="audio-player" preload="metadata"></audio>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
    
    <script>
        // ========== PLAYER TOÀN CỤC VỚI LOCALSTORAGE ==========
        let audio = document.getElementById("audio-player");
        let isInitialized = false;
        
        // BIẾN THEO DÕI THỜI GIAN NGHE
        let listenStartTime = null;
        let currentSongId = null;

        // Hàm toggle mute
        function toggleMute() {
            if (audio.volume > 0) {
                audio.volume = 0;
                volumeSlider.value = 0;
                showNotification('🔇 Đã tắt tiếng');
            } else {
                const savedVolume = localStorage.getItem('volume');
                const newVolume = savedVolume ? parseFloat(savedVolume) : 1;
                audio.volume = newVolume;
                volumeSlider.value = newVolume;
                showNotification('🔊 Đã bật tiếng');
            }
        }

        // Hàm hiển thị thông báo
        function showNotification(message) {
            let toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.animation = 'slideIn 0.3s ease-out reverse';
                setTimeout(() => toast.remove(), 300);
            }, 2000);
        }

        // Khôi phục trạng thái từ localStorage khi tải trang
        function restorePlayerState() {
            const savedSong = localStorage.getItem('currentSong');
            const savedTime = localStorage.getItem('currentTime');
            const savedPlaying = localStorage.getItem('isPlaying') === 'true';
            
            if (savedSong) {
                try {
                    const songData = JSON.parse(savedSong);
                    document.getElementById("player-title").innerText = songData.title;
                    document.getElementById("player-artist").innerText = songData.artist;
                    
                    let coverImg = document.getElementById("player-cover");
                    if (songData.cover && songData.cover !== 'https://via.placeholder.com/56') {
                        coverImg.src = songData.cover;
                        coverImg.style.display = "block";
                    } else {
                        coverImg.style.display = "none";
                    }
                    
                    audio.src = songData.filePath;
                    currentSongId = localStorage.getItem('currentSongId');
                    
                    if (savedTime && !isNaN(parseFloat(savedTime)) && savedTime > 0) {
                        audio.currentTime = parseFloat(savedTime);
                    }
                    
                    if (savedPlaying) {
                        listenStartTime = Date.now();
                        audio.play().catch(e => console.log("Auto-play bị chặn:", e));
                        setPlayIcon(true);
                    } else {
                        setPlayIcon(false);
                    }
                } catch(e) {
                    console.log("Khôi phục thất bại:", e);
                }
            }
            isInitialized = true;
        }
        
        // Lưu trạng thái hiện tại
        function savePlayerState() {
            if (!isInitialized) return;
            
            const currentSong = {
                filePath: audio.src,
                title: document.getElementById("player-title").innerText,
                artist: document.getElementById("player-artist").innerText,
                cover: document.getElementById("player-cover").src
            };
            
            if (audio.src && audio.src !== window.location.href && audio.src !== '') {
                localStorage.setItem('currentSong', JSON.stringify(currentSong));
                localStorage.setItem('currentTime', audio.currentTime);
                localStorage.setItem('isPlaying', !audio.paused);
                if (currentSongId) {
                    localStorage.setItem('currentSongId', currentSongId);
                }
            }
        }
        
        window.addEventListener('beforeunload', function() {
            savePlayerState();
            trackListeningTime();
        });
        
        setInterval(function() {
            if (audio.src && !audio.paused && audio.src !== '') {
                savePlayerState();
            }
        }, 5000);
        
        audio.addEventListener('timeupdate', function() {
            if (audio.src && !audio.paused && isInitialized && audio.src !== '') {
                localStorage.setItem('currentTime', audio.currentTime);
            }
        });
        
        // ========== DANH SÁCH PHÁT TOÀN CỤC ==========
        let currentPlaylist = [];
        let currentIndex = -1;
        
        function setPlaylist(songIds, newSongId) {
            currentPlaylist = songIds;
            currentIndex = currentPlaylist.indexOf(newSongId);
            localStorage.setItem('currentPlaylist', JSON.stringify(currentPlaylist));
            localStorage.setItem('currentIndex', currentIndex);
            console.log("Playlist updated:", currentPlaylist, "Current index:", currentIndex);
        }
        
        function restorePlaylist() {
            const savedPlaylist = localStorage.getItem('currentPlaylist');
            const savedIndex = localStorage.getItem('currentIndex');
            if (savedPlaylist) {
                currentPlaylist = JSON.parse(savedPlaylist);
                currentIndex = parseInt(savedIndex);
            }
        }
        
        function nextSong() {
            if (currentPlaylist.length === 0) {
                showNotification('📭 Không có bài hát trong playlist');
                return;
            }
            if (currentIndex < currentPlaylist.length - 1) {
                currentIndex++;
            } else {
                currentIndex = 0;
                showNotification('🔄 Đã phát lại từ đầu playlist');
            }
            playSongById(currentPlaylist[currentIndex]);
        }
        
        function prevSong() {
            if (currentPlaylist.length === 0) {
                showNotification('📭 Không có bài hát trong playlist');
                return;
            }
            if (currentIndex > 0) {
                currentIndex--;
            } else {
                currentIndex = currentPlaylist.length - 1;
            }
            playSongById(currentPlaylist[currentIndex]);
        }
        
        function playSongById(songId) {
            trackListeningTime();
            
            currentSongId = songId;
            listenStartTime = Date.now();

            showNotification('🎵 Đang tải bài hát...');
            
            fetch(`/Home/PlaySong?id=${songId}`)
                .then(res => res.json())
                .then(data => {
                    audio.src = data.filePath;
                    audio.play().catch(e => console.log("Play error:", e));
                    
                    document.getElementById("player-title").innerText = data.title;
                    document.getElementById("player-artist").innerText = data.artist;
                    
                    let coverImg = document.getElementById("player-cover");
                    if (data.cover && data.cover !== '/images/default-song.png') {
                        coverImg.src = data.cover;
                        coverImg.style.display = "block";
                    } else {
                        coverImg.style.display = "none";
                    }
                    
                    setPlayIcon(true);
                    savePlayerState();
                    showNotification(`🎵 Đang phát: ${data.title}`);
                })
                .catch(error => {
                    console.error("Error playing song:", error);
                    showNotification('⚠️ Không thể phát bài hát này');
                });
        }
        
        function playSong(id) {
            let songIds = [];
            document.querySelectorAll('[onclick^="playSong"]').forEach(btn => {
                let match = btn.getAttribute('onclick').match(/playSong\((\d+)\)/);
                if (match) songIds.push(parseInt(match[1]));
            });
            
            if (songIds.length === 0) songIds = [id];
            
            setPlaylist(songIds, id);
            playSongById(id);
        }
        
        function trackListeningTime(isCompleted = false) {
            if (currentSongId && listenStartTime) {
                const duration = Math.floor((Date.now() - listenStartTime) / 1000);
                if (duration >= 5) {
                    fetch('/Home/TrackListening?songId=' + currentSongId + '&duration=' + duration, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            songId: currentSongId,
                            duration: duration
                        })
                    }).catch(err => console.log("Lỗi ghi nhận thời gian:", err));
                }
                listenStartTime = null;
            }
        }

        audio.addEventListener("ended", () => {
            trackListeningTime(true);
            nextSong();
            savePlayerState();
        });

        function togglePlay() {
            if (!audio.src || audio.src === '') {
                showNotification('⚠️ Vui lòng chọn bài hát để phát');
                return;
            }
            if (audio.paused) {
                audio.play();
                setPlayIcon(true);
                listenStartTime = Date.now();
                showNotification('▶️ Đang phát');
            } else {
                audio.pause();
                setPlayIcon(false);
                trackListeningTime();
                showNotification('⏸️ Đã tạm dừng');
            }
            savePlayerState();
        }
        
        function togglePlayInfo() {
            if (audio.src && audio.src !== '') {
                // Có thể mở modal thông tin bài hát ở đây
                console.log("Current song info");
            }
        }
        
        function setPlayIcon(playing) {
            let icon = document.getElementById("play-icon");
            icon.classList.remove("fa-play", "fa-pause");
            icon.classList.add(playing ? "fa-pause" : "fa-play");
        }
        
        audio.addEventListener("timeupdate", () => {
            if (!audio.duration || isNaN(audio.duration)) return;
            let percent = (audio.currentTime / audio.duration) * 100;
            document.getElementById("progress-bar").style.width = percent + "%";
            document.getElementById("current-time").innerText = formatTime(audio.currentTime);
            document.getElementById("duration").innerText = formatTime(audio.duration);
        });
        
        function formatTime(seconds) {
            if (isNaN(seconds) || !isFinite(seconds)) return "0:00";
            let m = Math.floor(seconds / 60);
            let s = Math.floor(seconds % 60);
            return m + ":" + (s < 10 ? "0" + s : s);
        }
        
        function seek(e) {
            if (!audio.src || audio.src === '') return;
            let rect = e.currentTarget.getBoundingClientRect();
            let percent = (e.clientX - rect.left) / rect.width;
            audio.currentTime = percent * audio.duration;
            savePlayerState();
        }
        
        const volumeSlider = document.getElementById("volume");
        if (volumeSlider) {
            const savedVolume = localStorage.getItem('volume');
            if (savedVolume) {
                audio.volume = parseFloat(savedVolume);
                volumeSlider.value = savedVolume;
            }
            
            volumeSlider.addEventListener("input", function() {
                audio.volume = parseFloat(this.value);
                localStorage.setItem('volume', this.value);
            });
        }
        
        audio.addEventListener("play", () => {
            setPlayIcon(true);
            savePlayerState();
        });
        
        audio.addEventListener("pause", () => {
            setPlayIcon(false);
            savePlayerState();
        });

        audio.addEventListener("error", (e) => {
            console.error("Audio error:", e);
            showNotification('⚠️ Lỗi phát nhạc, vui lòng thử lại');
        });
        
        // Khởi tạo khi trang load
        document.addEventListener('DOMContentLoaded', function() {
            restorePlaylist();
            restorePlayerState();
        });

        // Chức năng nút Back và Forward
        function goBack() {
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        function goForward() {
            window.history.forward();
        }

        function updateNavButtons() {
            const btnBack = document.getElementById('btnBack');
            if (btnBack) {
                btnBack.style.opacity = window.history.length > 1 ? '1' : '0.5';
                btnBack.style.cursor = window.history.length > 1 ? 'pointer' : 'not-allowed';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            updateNavButtons();
            window.addEventListener('popstate', function() {
                updateNavButtons();
            });
        });

        document.addEventListener('keydown', function(event) {
            if (event.altKey && event.key === 'ArrowLeft') {
                event.preventDefault();
                goBack();
            }
            if (event.altKey && event.key === 'ArrowRight') {
                event.preventDefault();
                goForward();
            }
            // Thêm phím tắt space để play/pause
            if (event.code === 'Space' && document.activeElement !== document.querySelector('input')) {
                event.preventDefault();
                togglePlay();
            }
            // Phím mũi tên trái/phải để tua
            if (event.code === 'ArrowLeft' && !event.altKey && audio.src) {
                event.preventDefault();
                audio.currentTime = Math.max(0, audio.currentTime - 5);
            }
            if (event.code === 'ArrowRight' && !event.altKey && audio.src) {
                event.preventDefault();
                audio.currentTime = Math.min(audio.duration, audio.currentTime + 5);
            }
        });       
    </script>

</body>
</html>